  <section id="core" label="Core">
    <clause id="core.foundation">The foundation uses <ref>base</ref>.</clause>
    <section id="core.advanced" label="Advanced">
      <clause id="core.advanced.impl">The implementation uses <ref>derived</ref> and <ref>core.foundation</ref>.</clause>
    </section>
  </section>

  <section id="api" label="API">
    <clause id="api.endpoint">The endpoint references <ref>core.advanced.impl</ref> and <ref>base</ref>.</clause>
  </section>

</spec>
